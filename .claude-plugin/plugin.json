{
  "name": "workjournal",
  "version": "0.14.0",
  "description": "Cloud-hosted development journal for AI agents and developers",
  "mcpServers": {
    "workjournal": {
      "command": "npx",
      "args": ["-y", "@workjournal/mcp-server"],
      "env": {
        "WORKJOURNAL_API_URL": "https://api.workjournal.pro",
        "WORKJOURNAL_API_KEY": ""
      }
    }
  }
}
